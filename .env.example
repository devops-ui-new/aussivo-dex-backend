PORT=4000

# ═══ MONGODB ═══
# Option A: Free MongoDB Atlas (recommended — no installation needed)
#   1. Go to https://cloud.mongodb.com → Create free account
#   2. Create a FREE cluster → Click "Connect" → "Connect your application"  
#   3. Copy the connection string and paste below
#   Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/aussivo-dex
#
# Option B: Local MongoDB (requires installation)
#   brew install mongodb-community (Mac) or follow docs.mongodb.com
#   Then start with: brew services start mongodb-community
#   URI: mongodb://localhost:27017/aussivo-dex

MONGO_URI=mongodb://localhost:27017/aussivo-dex

JWT_SECRET=aussivo-dex-secret-change-in-production
ADMIN_EMAIL=admin@aussivo.com
ADMIN_PASS=Admin@123
ENVIRONMENT=development
CRON_SECRET=cron-secret-key

# Blockchain — defaults below are BSC TESTNET (chainId 97)
# For mainnet: RPC=https://bsc-dataseed1.binance.org, CHAIN_ID=56,
#              USDT=0x55d398326f99059fF775485246999027B3197955,
#              USDC=0x8AC76a51cc950d9822D68b83fE1Ad97B32Cd580d
# BSC RPC endpoint(s). Public dataseeds rate-limit eth_getLogs ("could not coalesce error").
# Use a dedicated provider (Ankr/QuickNode/NodeReal/BlockPI) for reliability. You may supply a
# COMMA-SEPARATED list of endpoints — the depositor-attribution log scan falls back across them.
# Example: BSC_PROVIDER_URL=https://your-dedicated-rpc,https://bsc-dataseed1.binance.org
BSC_PROVIDER_URL=https://data-seed-prebsc-1-s1.binance.org:8545
BSC_CHAIN_ID=97
VAULT_CONTRACT_ADDRESS=
USDT_CONTRACT_ADDRESS=0x337610d27c682E347C9cD60BD4b3b107C9d34dDd
USDC_CONTRACT_ADDRESS=0x64544969ed7EBf5f083679233325356EbE738930
ADMIN_WALLET_PRIVATE_KEY=

# Email (optional for dev — OTP prints in terminal)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Brevo on Railway: if connection times out on 587, use SMTP_PORT=465 (implicit TLS) instead.
# SMTP_IPV4_FIRST=true — use if SMTP host resolves to IPv6 but your network cannot reach it.
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@aussivo.com

# APY — yield is credited per deposit on rolling 30-day cycles (from each deposit's
# start date). The cron just needs to run often enough to catch those marks; daily is
# plenty. Use '0 * * * *' for hourly crediting.
APY_CRON_SCHEDULE=0 0 * * *
REFERRAL_L1_PERCENT=0.35
REFERRAL_L2_PERCENT=0.15
FRONTEND_URL=https://dex.aussivo.com

# ─── TRON / TRC20 USDT ───────────────────────────────────────────────
# Enables the "TRC-20" deposit option. Tron uses base58 addresses, 6-decimal USDT, and TRX/energy gas.
TRON_FULL_HOST=https://api.trongrid.io
TRON_API_KEY=                       # TronGrid API key (create at trongrid.io — strongly recommended)
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t   # mainnet USDT-TRC20
TRON_TREASURY_ADDRESS=              # where TRC20 deposits are swept (your Tron treasury, base58 T...)
TRON_GAS_FUNDER_PRIVATE_KEY=        # Tron wallet (hex key) holding TRX; funds energy for each sweep
TRON_GAS_TOPUP_TRX=35               # TRX sent to each ephemeral to cover one USDT transfer
