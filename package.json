{
  "name": "aussivo-dex-backend",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc",
    "start": "node ./build/index.js",
    "dev": "nodemon",
    "prebuild": "mkdir -p build/template && cp -a src/template build/"
  },
  "nodemonConfig": { "watch": ["src"], "ext": "ts", "exec": "ts-node src/index.ts" },
  "dependencies": {
    "bcryptjs": "^3.0.2", "cors": "^2.8.5", "dotenv": "^16.0.3",
    "ethers": "^6.14.4", "express": "^4.18.1", "handlebars": "^4.7.8",
    "helmet": "^8.1.0", "joi": "^17.13.3", "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.0", "morgan": "^1.10.0", "node-cron": "^3.0.3",
    "nodemailer": "^7.0.3", "nodemon": "^2.0.20", "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^7.2.0", "ts-node": "^10.9.1", "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6", "@types/cors": "^2.8.12",
    "@types/express": "^4.17.13", "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10", "@types/node": "^18.11.0", "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17", "@types/qrcode": "^1.5.5",
    "typescript": "^5.6.3"
  }
}
